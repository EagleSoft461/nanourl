# NanoURL Environment Variables
# Bu dosyayı .env olarak kopyala ve değerleri doldur:
#   cp .env.example .env

# ── Uygulama ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000
LOG_LEVEL=debug

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=nanourl
POSTGRES_PASSWORD=secret123
POSTGRES_DB=nanourl

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── JWT (RS256) ───────────────────────────────────────────────────────────────
# RSA key pair üretmek için:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Sonra tek satıra çevir:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' private.pem
JWT_PRIVATE_KEY=dev-secret-not-for-production
JWT_PUBLIC_KEY=dev-secret-not-for-production
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# ── Node ID (Snowflake ID generator) ─────────────────────────────────────────
# Her sunucu node'u için benzersiz bir değer (0-1023)
# Birden fazla instance varsa her biri farklı NODE_ID almalı
NODE_ID=1
