# Staging ortamı environment değişkenleri
# Bu dosyayı .env olarak kopyala ve gerçek değerleri doldur:
#   cp .env.staging.example .env
#
# Bu dosya repo'da — gerçek değerler ASLA commit edilmez

# PostgreSQL
POSTGRES_USER=nanourl
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=nanourl_staging

# Redis
REDIS_PASSWORD=change-me-redis-password

# API
STAGING_URL=https://staging.nanourl.io
API_IMAGE=ghcr.io/eaglesoft461/nanourl:latest

# JWT — RS256 key pair
# Üretmek için:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat private.pem | base64 -w 0
JWT_PRIVATE_KEY=base64-encoded-private-key
JWT_PUBLIC_KEY=base64-encoded-public-key
